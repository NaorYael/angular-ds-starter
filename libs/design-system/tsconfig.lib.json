{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "moduleResolution": "bundler"
  },
  "include": [
    "src/index.ts",
    "src/lib/ds-button/**/*.ts",
    "src/lib/ds-input/**/*.ts",
    "src/lib/ds-dialog/**/*.ts",
    "src/lib/ds-select/**/*.ts",
    "src/lib/ds-checkbox/**/*.ts",
    "src/lib/ds-badge/**/*.ts",
    "src/lib/ds-card/**/*.ts",
    "src/lib/ds-toast/**/*.ts",
    "src/lib/ds-textarea/**/*.ts",
    "src/lib/ds-switch/**/*.ts",
    "src/lib/ds-tabs/**/*.ts",
    "src/lib/ds-spinner/**/*.ts",
    "src/lib/ds-empty-state/**/*.ts",
    "src/lib/charts/**/*.ts",
    "src/lib/ds-radio/**/*.ts",
    "src/lib/ds-input-password/**/*.ts",
    "src/lib/ds-datepicker/**/*.ts",
    "src/lib/ds-menu/**/*.ts",
    "src/lib/ds-tooltip/**/*.ts",
    "src/lib/ds-avatar/**/*.ts",
    "src/lib/ds-skeleton/**/*.ts",
    "src/lib/ds-alert/**/*.ts",
    "src/lib/ds-tag/**/*.ts",
    "src/lib/ds-progress/**/*.ts",
    "src/lib/ds-breadcrumbs/**/*.ts",
    "src/lib/ds-stepper/**/*.ts",
    "src/lib/ds-pagination/**/*.ts",
    "src/lib/ds-table/**/*.ts",
    "src/lib/ds-drawer/**/*.ts",
    "src/lib/ds-autocomplete/**/*.ts",
    "src/lib/ds-multi-select/**/*.ts",
    "src/lib/ds-file-upload/**/*.ts"
  ],
  "exclude": ["**/*.spec.ts", "**/*.stories.ts"]
}
