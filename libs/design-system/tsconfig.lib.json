{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "moduleResolution": "bundler"
  },
  "include": [
    "src/index.ts",
    "src/lib/ds-button/**/*.ts",
    "src/lib/ds-input/**/*.ts",
    "src/lib/ds-dialog/**/*.ts",
    "src/lib/ds-select/**/*.ts",
    "src/lib/ds-checkbox/**/*.ts",
    "src/lib/ds-badge/**/*.ts",
    "src/lib/ds-card/**/*.ts",
    "src/lib/ds-toast/**/*.ts"
  ],
  "exclude": ["**/*.spec.ts", "**/*.stories.ts"]
}
